{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "ctaalert",
	"main": "src/index.ts",
	"compatibility_date": "2026-03-28",
	"observability": {
		"enabled": true,
	},
	"triggers": {
		"crons": [
			"*/5 * * * *"
		],
	},
	"upload_source_maps": true,
	"compatibility_flags": [
		"nodejs_compat"
	],
	"d1_databases": [
		{
			"binding": "alerts",
			"database_name": "alerts",
			"database_id": "a4c5f869-5743-4fdf-a00c-508eacef4389",
			"remote": true
		}
	],
}