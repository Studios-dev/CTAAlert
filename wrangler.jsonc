{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "ctaalert",
	"main": "src/index.ts",
	"compatibility_date": "2026-03-28",
	"observability": {
		"enabled": true,
	},
	"triggers": {
		"crons": [
			"*/5 * * * *"
		],
	},
	"upload_source_maps": true,
	"compatibility_flags": [
		"nodejs_compat"
	],
	"d1_databases": [
		{
			"binding": "ctaalert",
			"database_name": "ctaalert",
			"database_id": "a0831426-ed9d-4bcf-bc8d-de2ba5115185",
			"remote": true
		}
	],
}